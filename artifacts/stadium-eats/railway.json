{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm i -g pnpm && pnpm install --ignore-scripts && pnpm run build"
  },
  "deploy": {
    "startCommand": "npx serve dist/public -p 8080",
    "restartPolicyType": "ON_FAILURE"
  }
}
